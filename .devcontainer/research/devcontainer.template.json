{
  "name": "leash-research",
  "build": { "dockerfile": "Dockerfile" },
  "remoteUser": "dev",
  "containerUser": "dev",

  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW"
  ],

  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",

  "mounts": [
    "source=agent-auth-research,target=/home/dev/.claude,type=volume",
    "source=gh-auth-research,target=/home/dev/.config/gh,type=volume"
  ],

  "containerEnv": {
    "LEASH_ENV": "research",
    "HARNESS_PATH": "/workspace",
    "REPOS_PATH": "/workspace/repos",
    "RESEARCH_DRAFTS_PATH": "/workspace/target-state/research/drafts",

    "//proxy": "Default egress route: the squid hostname-allowlist proxy started by init-firewall.sh. CLIs (aws, kubectl, gh, curl) honor these and so reach allowlisted platform endpoints regardless of IP rotation. Set in both cases so a tool that reads only one form still routes correctly.",
    "HTTP_PROXY": "http://127.0.0.1:3128",
    "HTTPS_PROXY": "http://127.0.0.1:3128",
    "http_proxy": "http://127.0.0.1:3128",
    "https_proxy": "http://127.0.0.1:3128",
    "NO_PROXY": "localhost,127.0.0.1,::1",
    "no_proxy": "localhost,127.0.0.1,::1"
  },

  "postCreateCommand": "bash /workspace/.devcontainer/research/post-create.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code"
      ]
    }
  }
}
