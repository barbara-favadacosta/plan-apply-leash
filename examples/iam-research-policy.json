{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BroadReadOnlyAcrossCommonServices",
      "Effect": "Allow",
      "Action": [
        "ec2:Describe*",
        "ec2:List*",
        "ec2:Get*",
        "s3:Get*",
        "s3:List*",
        "lambda:Get*",
        "lambda:List*",
        "iam:Get*",
        "iam:List*",
        "rds:Describe*",
        "rds:List*",
        "dynamodb:Describe*",
        "dynamodb:List*",
        "dynamodb:Scan",
        "dynamodb:Query",
        "ecs:Describe*",
        "ecs:List*",
        "eks:Describe*",
        "eks:List*",
        "logs:Describe*",
        "logs:Get*",
        "logs:List*",
        "logs:FilterLogEvents",
        "logs:StartQuery",
        "logs:GetQueryResults",
        "cloudformation:Describe*",
        "cloudformation:List*",
        "cloudformation:Get*",
        "cloudwatch:Describe*",
        "cloudwatch:Get*",
        "cloudwatch:List*",
        "sts:GetCallerIdentity",
        "tag:Get*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenySensitiveReadsEvenInResearch",
      "Effect": "Deny",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:GetResourcePolicy",
        "kms:Decrypt",
        "kms:GenerateDataKey",
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:GetParametersByPath",
        "rds:DownloadDBLogFilePortion"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyAllWritesEverywhere",
      "Effect": "Deny",
      "Action": [
        "*:Create*",
        "*:Update*",
        "*:Put*",
        "*:Delete*",
        "*:Modify*",
        "*:Attach*",
        "*:Detach*",
        "*:Terminate*",
        "*:Stop*",
        "*:Start*",
        "*:Invoke*",
        "*:Run*",
        "iam:*"
      ],
      "Resource": "*"
    }
  ]
}
