{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ApplyPlan",
  "description": "Multi-repo apply plan. scope.repos is a map of local subdir slug → repo config; the agent works in /workspace/repos/<slug>/ per scope.repos entry.",
  "type": "object",
  "additionalProperties": false,
  "required": ["plan_id", "description", "scope", "steps"],
  "properties": {
    "plan_id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z0-9-]{3,60}$",
      "description": "yyyy-mm-dd-slug"
    },
    "description": {
      "type": "string",
      "minLength": 20,
      "maxLength": 2000
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repos"],
      "properties": {
        "repos": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 10,
          "patternProperties": {
            "^[a-zA-Z0-9._-]+$": {
              "type": "object",
              "additionalProperties": false,
              "required": ["github", "branch", "file_paths"],
              "properties": {
                "github": {
                  "type": "string",
                  "pattern": "^[A-Za-z0-9._-]+/[A-Za-z0-9._-]+$",
                  "description": "org/repo identifier; matched against gh remote for sanity"
                },
                "branch": {
                  "type": "string",
                  "pattern": "^[A-Za-z0-9._/-]+$",
                  "maxLength": 100,
                  "description": "Branch the apply session creates and pushes to. REQUIRED: the harness blocks every edit in a repo until that repo is on this branch (branch-first enforcement), so every change lands on a new branch. Must not be a default branch (main/master/HEAD)."
                },
                "pr_title": {
                  "type": "string",
                  "minLength": 5,
                  "maxLength": 200
                },
                "pr_body": {
                  "type": "string",
                  "maxLength": 4000
                },
                "file_paths": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 100,
                  "description": "Repo-relative paths the agent may edit. Each is either an exact file (e.g. 'src/handler.ts') or a directory subtree glob with a trailing '/**' (e.g. 'src/**'), which grants every file under that directory. '**' is allowed ONLY as a whole trailing path segment — no other wildcards.",
                  "items": {
                    "type": "string",
                    "pattern": "^[A-Za-z0-9._/-]+(/\\*\\*)?$",
                    "maxLength": 256
                  }
                }
              }
            }
          },
          "additionalProperties": false
        },
        "aws_resources": {
          "type": "array",
          "maxItems": 50,
          "description": "Informational only — apply env has no AWS access. Listed for human review and CI/CD handoff.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["arn", "actions"],
            "properties": {
              "arn": {
                "type": "string",
                "pattern": "^arn:aws:[a-z0-9-]+:[a-z0-9-]*:[0-9]*:.+$"
              },
              "actions": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[a-z0-9]+:[A-Za-z0-9*]+$"
                }
              }
            }
          }
        },
        "allowed_command_prefixes": {
          "type": "array",
          "maxItems": 50,
          "description": "Shell command prefixes the agent may run, applied across all repos.",
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9 _.+/-]+$",
            "maxLength": 200
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "description"],
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "repo": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9._-]+$",
            "description": "Must reference a key in scope.repos. Required for file_edit, file_create, file_delete, github_action; optional for command (commands without 'repo' run in /workspace/repos/) and aws_action (informational, doesn't run)."
          },
          "type": {
            "enum": ["file_edit", "file_create", "file_delete", "command", "aws_action", "github_action"]
          },
          "description": {
            "type": "string",
            "minLength": 5,
            "maxLength": 1000
          },
          "path": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._/-]+$",
            "description": "Workspace-relative path within the named repo (e.g. 'src/handler.ts'). Used by file_edit/file_create/file_delete."
          },
          "command_prefix": {
            "type": "string",
            "maxLength": 200,
            "description": "Must match one of scope.allowed_command_prefixes. Used by command steps."
          },
          "aws_action": {
            "type": "string",
            "pattern": "^[a-z0-9]+:[A-Za-z0-9*]+$",
            "description": "Informational only — apply env has no AWS access."
          },
          "aws_arn": {
            "type": "string",
            "pattern": "^arn:aws:[a-z0-9-]+:[a-z0-9-]*:[0-9]*:.+$",
            "description": "Informational only — apply env has no AWS access."
          }
        }
      }
    }
  }
}
