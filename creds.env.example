# creds.env — single credentials file for the plan-apply-leash harness.
#
# Copy this file to a location OUTSIDE this repo and fill it in:
#
#     mkdir -p ~/.config/plan-apply-leash
#     cp creds.env.example ~/.config/plan-apply-leash/creds.env
#     $EDITOR ~/.config/plan-apply-leash/creds.env
#
# Then run `scripts/setup.sh`. (Override the location with $LEASH_CREDS.)
#
# This file holds only POINTERS and non-secret config — no token text. Just as a
# research-access.yaml platform points `credential:` at a host dir/file, the
# GitHub entries point at files that hold the PATs. Keep this file and the token
# files outside the workspace: the
# project folder is bind-mounted into both devcontainers at /workspace, so a
# secret in the tree would be readable from the read-only research env.
#
# setup.sh sources this file (so $HOME and quotes are expanded by the shell),
# reads each PAT from the file it points at, bakes the non-secret values into
# the generated devcontainer.json, and writes the tokens to per-env files that
# Docker injects via --env-file. The tokens never enter the workspace.

# ── GitHub fine-grained PATs (both required) ────────────────────────────────
# Point each at a file containing ONLY the PAT (one line). Create them like:
#     printf '%s' 'github_pat_...' > ~/.config/plan-apply-leash/gh-research.token
#     chmod 600 ~/.config/plan-apply-leash/gh-research.token
# See examples/github-pat-scopes.md for the exact scopes.
export GH_TOKEN_RESEARCH_FILE="$HOME/.config/plan-apply-leash/gh-research.token"  # read across orgs
export GH_TOKEN_APPLY_FILE="$HOME/.config/plan-apply-leash/gh-apply.token"        # write, repo-scoped

# ── Apply-env git identity (the agent commits as this) ──────────────────────
# The apply container's base image sets no git user.name/email, so commits would
# error or prompt. gen_devcontainer.py bakes these into the apply container and
# post-create.sh runs `git config --global` from them (fail-closed if unset).
# Use your corporate identity. Defaults are baked in if you leave these unset.
export GIT_IDENTITY_NAME="John Doe"
export GIT_IDENTITY_EMAIL="jdoe@email.com"

# ── Read-only platform access for research (AWS, Kubernetes, anything) ───────
# Declared in research-access.yaml, NOT here — it's a structured list, not flat
# env vars. Copy research-access.yaml.example to research-access.yaml and add a
# platform entry per credential you want the research agent to read. Omit it
# entirely and research runs with GitHub only. The APPLY env never gets any of
# these — it has a scoped GitHub token and nothing else.

# ── Extra egress domains (optional) ─────────────────────────────────────────
# Space-separated hostnames to add to the research egress allowlist on top of
# whatever research-access.yaml's platforms contribute. Usually empty — prefer
# putting a platform's domains on its research-access.yaml entry.
export ALLOWED_DOMAINS_EXTRA=""
